# ── Email (Gmail SMTP) ──────────────────────────────────────────
# Use a Gmail App Password (NOT your regular Gmail password):
# https://myaccount.google.com/apppasswords

SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password-here

# Who receives the notifications (can be same as SMTP_USER)
NOTIFY_EMAIL=your@gmail.com

# ── Optional: protect the /api/sync endpoint ────────────────────
SYNC_SECRET=change-this-to-a-random-secret


GITHUB_TOKEN=your-github-personal-access-token

# ── Public subscriptions ─────────────────────────────────────────
# Repo where subscribers.json lives (owner/repo)
GITHUB_REPO=pratyush06-aec/gssoc_pr_tracker
# Full URL of your deployed app (used for unsubscribe links in emails)
APP_URL=https://gssoc-pr-tracker.vercel.app

# ── GitHub Actions also needs these as repository secrets ────────
# Settings → Secrets → Actions → New repository secret:
#   SMTP_USER, SMTP_PASS, NOTIFY_EMAIL, SYNC_SECRET, GITHUB_TOKEN, GH_REPO, APP_URL
# Note: GITHUB_TOKEN is auto-provided by Actions — do NOT add it as a secret if you use the default one, but for subscribers.json you need a PAT.
